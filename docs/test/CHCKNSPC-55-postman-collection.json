                  "// với thứ tự khác ['ho','sot','dau_dau'] phải trả về cùng cache hit.",
                  "// Verify: response time của TC-04 phải tương tự TC-02 lần 2 (cache hit)",
                  "pm.test('Recommendations không rỗng (cache hit từ TC-02)', () => {",
                  "  pm.expect(pm.response.json().data.recommendations).to.be.an('array').and.to.have.length.greaterThan(0);",
                  "});",
                  "console.log('[TC-04] Response time (kỳ vọng cache hit):', pm.response.responseTime + 'ms');"
                ],
