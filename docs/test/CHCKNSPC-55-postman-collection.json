            "body": {
              "mode": "raw",
              "raw": "{\n  \"symptoms\": [\"ho\", \"sot\", \"dau_dau\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/symptoms/check",
              "host": ["{{base_url}}"],
              "path": ["symptoms", "check"]
            },
            "description": "Symptoms order-independent cache: ['ho','sot','dau_dau'] phải hit cùng cache key với ['sot','dau_dau','ho'] do Service dùng .sort().join('-')."
          }
        },
