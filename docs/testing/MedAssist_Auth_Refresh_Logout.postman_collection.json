              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Joi string().required() rejects empty string."
          }
        },
        {
          "name": "TC-10: Refresh — JWT hết hạn (expired)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('code = INVALID_REFRESH_TOKEN', () => {",
                  "  pm.expect(pm.response.json().code).to.eql('INVALID_REFRESH_TOKEN');",
                  "});",
                  "pm.test('success = false', () => {",
                  "  pm.expect(pm.response.json().success).to.be.false;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{expired_refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "/auth/refresh does NOT use ignoreExpiration → TokenExpiredError → 401. Contrast with TC-05 (logout which ignores expiration)."
          }
        },
        {
          "name": "TC-12: Refresh — user không tồn tại trong DB",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('code = USER_NOT_FOUND', () => {",
