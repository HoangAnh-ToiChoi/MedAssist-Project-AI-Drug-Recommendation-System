{
  "info": {
    "_postman_id": "medassist-auth-refresh-logout-v1",
    "name": "MedAssist — Auth: Refresh & Logout (Redis)",
    "description": "Test suite for POST /auth/refresh and POST /auth/logout.\nFeature: Redis-backed refresh token with rotation and revocation.\n\nBranch: feature/CHCKNSPC-42-HA-auth-login\nDate: 2026-05-21\nAuthor: HA\n\nIMPORTANT: Set environment variables before running:\n  - base_url          : http://localhost:3000/api/v1\n  - valid_email       : (a registered, active user)\n  - valid_password    : (password for above user)\n  - valid_refresh_token: (auto-set by TC-00 Pre-flight Login)\n  - old_refresh_token  : (manually capture before TC-01)\n  - expired_refresh_token: (JWT with correct sig but past exp)\n  - access_token       : (auto-set by TC-00)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "event": [],
  "item": [
    {
      "name": "TC-00: Pre-flight — Login to get tokens",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has accessToken', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.accessToken).to.be.a('string');",
              "  pm.expect(json.data.refreshToken).to.be.a('string');",
              "  pm.environment.set('access_token', json.data.accessToken);",
              "  pm.environment.set('valid_refresh_token', json.data.refreshToken);",
              "  console.log('[TC-00] Tokens saved to environment.');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{valid_email}}\",\n  \"password\": \"{{valid_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth", "login"]
        },
        "description": "Pre-flight: login to get a fresh refresh token. Saves access_token and valid_refresh_token to environment."
      }
    },
    {
      "name": "FUNCTIONAL — HAPPY PATH",
      "item": [
        {
          "name": "TC-01: Refresh token hợp lệ",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Save the current refresh token as 'old' before rotating",
                  "pm.environment.set('old_refresh_token', pm.environment.get('valid_refresh_token'));",
                  "console.log('[TC-01] Saved old_refresh_token:', pm.environment.get('old_refresh_token').substring(0,30) + '...');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Response time < 2000ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test('success = true', () => {",
                  "  pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "",
                  "pm.test('message = Làm mới token thành công', () => {",
                  "  pm.expect(pm.response.json().message).to.eql('Làm mới token thành công');",
                  "});",
                  "",
                  "pm.test('data has accessToken, refreshToken, user', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d.accessToken).to.be.a('string').and.match(/^eyJ/);",
                  "  pm.expect(d.refreshToken).to.be.a('string').and.match(/^eyJ/);",
                  "  pm.expect(d.user).to.have.keys(['id', 'email', 'fullName', 'role']);",
                  "});",
                  "",
                  "pm.test('Token rotation: new refreshToken differs from old', () => {",
                  "  const newToken = pm.response.json().data.refreshToken;",
                  "  const oldToken = pm.environment.get('old_refresh_token');",
                  "  pm.expect(newToken).to.not.eql(oldToken);",
                  "  pm.environment.set('valid_refresh_token', newToken);",
                  "  console.log('[TC-01] Token rotation verified. New token saved.');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{valid_refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Happy path: valid refresh token → get new access + refresh token pair. Saves new token for subsequent tests."
          }
        },
        {
          "name": "TC-03: Logout hợp lệ",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Re-login to get a fresh token for this test because TC-01 rotated it",
                  "console.log('[TC-03] Using current valid_refresh_token:', pm.environment.get('valid_refresh_token').substring(0,30) + '...');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Response time < 2000ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test('success = true', () => {",
                  "  pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "",
                  "pm.test('message = Đăng xuất thành công', () => {",
                  "  pm.expect(pm.response.json().message).to.eql('Đăng xuất thành công');",
                  "});",
                  "",
                  "pm.test('data = null', () => {",
                  "  pm.expect(pm.response.json().data).to.be.null;",
                  "});",
                  "",
                  "console.log('[TC-03] Logout done. valid_refresh_token is now revoked in Redis.');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{valid_refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Happy path: logout with valid token → 200 and token revoked from Redis."
          }
        }
      ]
    },
    {
      "name": "BUSINESS RULES",
      "item": [
        {
          "name": "TC-02: Token Rotation — old refresh token bị reject sau rotate",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "",
                  "pm.test('Response time < 2000ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test('success = false', () => {",
                  "  pm.expect(pm.response.json().success).to.be.false;",
                  "});",
                  "",
                  "pm.test('code = INVALID_REFRESH_TOKEN', () => {",
                  "  pm.expect(pm.response.json().code).to.eql('INVALID_REFRESH_TOKEN');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{old_refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Business Rule: Token Rotation. Must run AFTER TC-01. old_refresh_token was set in TC-01 pre-request. Redis now has the NEW token → old one rejected."
          }
        },
        {
          "name": "TC-04: Sau logout — refresh token bị reject",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "",
                  "pm.test('Response time < 2000ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test('success = false', () => {",
                  "  pm.expect(pm.response.json().success).to.be.false;",
                  "});",
                  "",
                  "pm.test('code = INVALID_REFRESH_TOKEN', () => {",
                  "  pm.expect(pm.response.json().code).to.eql('INVALID_REFRESH_TOKEN');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{valid_refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Business Rule: Sau logout, refresh token cũ không dùng được. Must run AFTER TC-03. valid_refresh_token đã bị xóa khỏi Redis."
          }
        },
        {
          "name": "TC-05: Logout với expired token — vẫn 200 (silent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Response time < 2000ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test('success = true (silent on expired)', () => {",
                  "  pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "",
                  "pm.test('data = null', () => {",
                  "  pm.expect(pm.response.json().data).to.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{expired_refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Business Rule: logout() dùng ignoreExpiration:true → expired token vẫn decode được nếu chữ ký đúng → Redis del. Nếu chữ ký cũng sai → silent return → vẫn 200."
          }
        }
      ]
    },
    {
      "name": "FUNCTIONAL — ERROR CASES",
      "item": [
