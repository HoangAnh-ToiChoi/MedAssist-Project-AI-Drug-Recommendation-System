    {
      "name": "SECURITY",
      "item": [
        {
          "name": "TC-09: Security — JWT chữ ký bị tamper",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('code = INVALID_REFRESH_TOKEN', () => {",
                  "  pm.expect(pm.response.json().code).to.eql('INVALID_REFRESH_TOKEN');",
                  "});",
                  "pm.test('success = false', () => {",
                  "  pm.expect(pm.response.json().success).to.be.false;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiIxMjM0NTY3OC0xMjM0LTEyMzQtMTIzNC0xMjM0NTY3ODkwMTIiLCJpYXQiOjE3MTY0NTgwMDAsImV4cCI6OTk5OTk5OTk5OX0.INVALID_TAMPERED_SIGNATURE_XXXXXXXXXXX\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Security: tampered JWT signature → JsonWebTokenError → catch → 401. Even if userId in payload is real, wrong signature blocks access."
          }
        },
        {
          "name": "TC-11: Security — Logout với JWT chữ ký sai → 200 silent",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 (silent fail on bad sig)', () => pm.response.to.have.status(200));",
                  "pm.test('success = true', () => {",
                  "  pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.test('data = null', () => {",
                  "  pm.expect(pm.response.json().data).to.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJmYWtlLXVzZXItaWQiLCJpYXQiOjE3MTY0NTgwMDB9.BAD_SIG\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Security: logout() silently ignores bad signature (catch → return). Returns 200 without leaking info. Redis NOT modified since we never reach redis.del()."
          }
        },
        {
          "name": "TC-19: Security — dùng access token thay vì refresh token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('code = INVALID_REFRESH_TOKEN', () => {",
                  "  pm.expect(pm.response.json().code).to.eql('INVALID_REFRESH_TOKEN');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{access_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Security: access token signed with JWT_SECRET, but refresh endpoint uses JWT_REFRESH_SECRET → signature mismatch → 401. Prevents token type confusion attacks."
          }
        },
        {
          "name": "TC-16: Security — Payload quá lớn (10KB string)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate a ~10KB string",
                  "const bigString = 'A'.repeat(10240);",
                  "pm.environment.set('big_payload', bigString);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Not 200 — large payload rejected or JWT-failed', () => {",
                  "  // Acceptable: 400 (Joi no max), 413 (body limit), or 401 (jwt.verify fails on huge non-JWT string)",
                  "  pm.expect(pm.response.code).to.be.oneOf([400, 401, 413]);",
                  "});",
                  "pm.test('Response time < 2000ms even for large payload', () => {",
