              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{valid_jwt_redis_deleted}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Scenario: Redis restart / TTL expired. Token valid JWT but Redis key 'refresh:{userId}' manually deleted. stored === null → 401. Setup: login, then DEL the Redis key via redis-cli, then use that token."
          }
        },
        {
          "name": "TC-20: Refresh — sai field name (refresh_token thay vì refreshToken)",
          "event": [
            {
              "listen": "test",
              "script": {
